# ===================================================
# Infraticket - Variables de entorno (LOCAL)
# ===================================================
# Copia este archivo: cp .env.example .env
# NUNCA subas .env a Git (está en .gitignore)
# ===================================================

# ---- MariaDB ----
MYSQL_ROOT_PASSWORD=RootLocal123!
MYSQL_DATABASE=mariadb
MYSQL_USER=glpi_user
MYSQL_PASSWORD=GlpiLocal456!

# ---- Zona horaria ----
TIMEZONE=Europe/Madrid

# ---- OpenLDAP ----
LDAP_DOMAIN=infraticket.local 
LDAP_ADMIN_PASSWORD=LdapLocal789!
# cn=admin,dc=infraticket,dc=local

# ---- Grafana ----
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ----- GLPI ------
GLPI_ADMIN_USER=glpi
GLPI_ADMIN_PASSWORD=glpi
